# Supabase 설정
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth 설정
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key-here

# Google OAuth 설정
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack 알림 설정 (선택 — 연차 신청·승인 알림)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL_ID=C01234ABCDE

# Google Calendar 동기화 설정 (선택 — 승인된 연차를 그룹 캘린더에 자동 등록)
GOOGLE_CALENDAR_GROUP_ID=your-calendar-group-id@group.calendar.google.com

# 이메일 발송 설정 (선택 — Resend로 알림 메일)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourcompany.com

# Vercel Cron 인증 (선택 — 상태 전환 자동화 endpoint 보호)
CRON_SECRET=your-random-cron-secret
